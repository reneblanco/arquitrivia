<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <!-- Fondo crema del brand -->
  <rect width="1200" height="630" fill="#faf9f6" />

  <!-- Grid pattern sutil -->
  <defs>
    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#000000" stroke-width="1" opacity="0.08" />
    </pattern>
  </defs>
  <rect width="1200" height="630" fill="url(#grid)" />

  <!-- Logo arriba a la izquierda -->
  <g transform="translate(70, 60)">
    <g fill="none" stroke="#000000" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="2" y1="38" x2="42" y2="38" />
      <line x1="9" y1="38" x2="9" y2="20" />
      <line x1="22" y1="38" x2="22" y2="20" />
      <line x1="35" y1="38" x2="35" y2="20" />
      <line x1="2" y1="20" x2="42" y2="20" />
      <polyline points="2,20 22,8 42,20" />
    </g>
    <text x="55" y="32" font-family="ui-sans-serif, system-ui, sans-serif" font-size="32" font-weight="900" fill="#000000" letter-spacing="-1.2">arquitrivia</text>
  </g>

  <!-- Tag box amarilla -->
  <g transform="translate(70, 150) rotate(-1.5)">
    <rect x="0" y="0" width="280" height="44" fill="#ffe600" stroke="#000000" stroke-width="4" />
    <text x="140" y="30" font-family="ui-sans-serif, system-ui, sans-serif" font-size="16" font-weight="900" fill="#000000" letter-spacing="2" text-anchor="middle">PARA PROFES Y ALUMNOS</text>
  </g>

  <!-- Línea 1 -->
  <text x="70" y="290" font-family="ui-sans-serif, system-ui, sans-serif" font-size="80" font-weight="900" fill="#000000" letter-spacing="-3">Haz inolvidables</text>

  <!-- Línea 2 -->
  <text x="70" y="380" font-family="ui-sans-serif, system-ui, sans-serif" font-size="80" font-weight="900" fill="#000000" letter-spacing="-3">tus clases de</text>

  <!-- Línea 3 con highlight rojo -->
  <g transform="translate(60, 410)">
    <rect x="0" y="0" width="730" height="84" fill="#ff3366" stroke="#000000" stroke-width="5" />
    <text x="20" y="62" font-family="ui-sans-serif, system-ui, sans-serif" font-size="68" font-weight="900" fill="#ffffff" letter-spacing="-2.5">ARQUITECTURA.</text>
  </g>

  <!-- URL bottom-right -->
  <g transform="translate(1130, 580)">
    <rect x="-220" y="-30" width="220" height="44" fill="#ffe600" stroke="#000000" stroke-width="4" />
    <text x="-110" y="-2" font-family="ui-sans-serif, system-ui, sans-serif" font-size="20" font-weight="900" fill="#000000" letter-spacing="1" text-anchor="middle">arquitrivia.com</text>
  </g>

  <!-- Borde brutalist -->
  <rect x="6" y="6" width="1188" height="618" fill="none" stroke="#000000" stroke-width="12" />
</svg>
